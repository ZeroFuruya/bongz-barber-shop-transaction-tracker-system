            <VBox prefHeight="430.0" prefWidth="520.0" spacing="12.0">
               <children>
                  <Label fx:id="titleLabel" styleClass="modal-title" text="Add Barber" />
                  <HBox spacing="12.0">
                     <children>
                        <Label fx:id="barberIdLabel" text="Barber ID: New" />
                        <Label fx:id="createdAtLabel" text="Created At: (new)" wrapText="true" />
                     </children>
                  </HBox>
                  <VBox spacing="6.0">
                     <children>
                        <Label text="Barber Name" />
                        <TextField fx:id="nameField" promptText="Enter barber name" />
                     </children>
                  </VBox>
                  <VBox spacing="6.0">
                     <children>
                        <Label text="Barber Image" />
                        <TextField fx:id="imagePathField" editable="false" promptText="No image selected yet" />
                        <HBox spacing="10.0">
                           <children>
                              <Button fx:id="browseImageButton" mnemonicParsing="false" onAction="#handleBrowseImage" prefWidth="120.0" text="Browse Image" />
                              <Button fx:id="clearImageButton" mnemonicParsing="false" onAction="#handleClearImage" prefWidth="120.0" text="Clear Image" />
                           </children>
                        </HBox>
                        <Label fx:id="imageHelpLabel" text="Selected image will be copied into the app data folder when you save." wrapText="true" />
