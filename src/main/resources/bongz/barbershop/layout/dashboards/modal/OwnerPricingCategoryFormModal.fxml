<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<Pane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="560.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/13" xmlns:fx="http://javafx.com/fxml/1" fx:controller="bongz.barbershop.layout.dashboards.modal.OwnerPricingCategoryFormModalController">
   <children>
      <StackPane prefHeight="560.0" prefWidth="600.0" style="-fx-background-color: #f5f1ea; -fx-background-radius: 12px;">
         <children>
            <VBox prefHeight="520.0" prefWidth="560.0" spacing="12.0">
               <children>
                  <Label fx:id="titleLabel" style="-fx-font-size: 20px; -fx-font-weight: bold;" text="Add Pricing Category" />
                  <HBox spacing="12.0">
                     <children>
                        <Label fx:id="pricingIdLabel" text="Pricing ID: New" />
                        <Label fx:id="defaultStatusLabel" text="Default: No" />
                        <Label fx:id="createdAtLabel" text="Created At: (new)" wrapText="true" />
                     </children>
                  </HBox>
                  <HBox spacing="12.0">
                     <children>
                        <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                           <children>
                              <Label text="Code" />
                              <TextField fx:id="codeField" promptText="CLASSIC" />
                           </children>
                        </VBox>
                        <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                           <children>
                              <Label text="Name" />
                              <TextField fx:id="nameField" promptText="Classic Cut" />
                           </children>
                        </VBox>
                     </children>
                  </HBox>
                  <VBox spacing="6.0">
                     <children>
                        <Label text="Description" />
                        <TextArea fx:id="descriptionTextArea" prefHeight="110.0" promptText="Optional description" wrapText="true" />
                     </children>
                  </VBox>
                  <HBox spacing="12.0">
                     <children>
                        <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                           <children>
                              <Label text="Charged Amount" />
                              <TextField fx:id="chargedAmountField" promptText="100" />
                           </children>
                        </VBox>
                        <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                           <children>
                              <Label text="Commission Percent" />
                              <TextField fx:id="commissionPercentField" promptText="60" />
                           </children>
                        </VBox>
                        <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                           <children>
                              <Label text="Sort Order" />
                              <TextField fx:id="sortOrderField" promptText="Optional" />
                           </children>
                        </VBox>
                     </children>
                  </HBox>
                  <CheckBox fx:id="activeCheckBox" mnemonicParsing="false" selected="true" text="Pricing category is active" />
                  <Label fx:id="statusLabel" text="" wrapText="true" />
                  <HBox alignment="CENTER_RIGHT" spacing="10.0">
                     <children>
                        <Button fx:id="saveButton" mnemonicParsing="false" onAction="#handleSave" prefWidth="120.0" text="Save" />
                        <Button mnemonicParsing="false" onAction="#handleCancel" prefWidth="120.0" text="Cancel" />
                     </children>
                  </HBox>
               </children>
            </VBox>
         </children>
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
         </padding>
      </StackPane>
